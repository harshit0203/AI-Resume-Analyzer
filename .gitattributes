# Normalize line endings to LF in the repository; checkout as-is on Windows.
* text=auto eol=lf

# Binaries — never touch line endings
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary
*.pdf  binary
*.docx binary
*.zip  binary
*.gz   binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.eot  binary
