# ----------------------------------------------------------------------------
# AIResumeAnalyzer — Backend environment variables
# Copy to `.env` and fill in the values. Do NOT commit your real `.env`.
# ----------------------------------------------------------------------------

# Application
PROJECT_NAME=
ENVIRONMENT=
DEBUG=
LOG_LEVEL=
API_V1_PREFIX=
BACKEND_URL=
FRONTEND_URL=
CORS_ORIGINS=

# Database (PostgreSQL — async driver)
DATABASE_URL=
DATABASE_ECHO=
DB_POOL_SIZE=
DB_MAX_OVERFLOW=

# Redis
REDIS_URL=
REDIS_CACHE_TTL=

# JWT / Security
JWT_SECRET_KEY=
JWT_REFRESH_SECRET_KEY=
JWT_ALGORITHM=
ACCESS_TOKEN_EXPIRE_MINUTES=
REFRESH_TOKEN_EXPIRE_DAYS=
BCRYPT_ROUNDS=

# Cookies
COOKIE_NAME=
COOKIE_SECURE=
COOKIE_SAMESITE=
COOKIE_DOMAIN=

# OpenAI / AI
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_TEMPERATURE=
AI_ENABLED=

# File storage
STORAGE_BACKEND=
UPLOAD_DIR=
MAX_UPLOAD_SIZE_MB=
ALLOWED_UPLOAD_EXTENSIONS=

# Optional S3 storage
S3_BUCKET=
S3_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Rate limiting
RATE_LIMIT_ENABLED=
RATE_LIMIT_DEFAULT=
RATE_LIMIT_AUTH=
